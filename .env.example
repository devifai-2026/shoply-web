# Leave VITE_API_URL unset for both local dev and production builds.
# src/config.js already falls back to http://localhost:5000 when running on
# localhost, and to the app's own origin otherwise (so it works correctly on
# any tenant subdomain). Only set this to point local dev at a REMOTE server
# instead of localhost:5000 — and never set it in .env.production, since
# Vite's loadEnv() merges .env into every build mode and won't unset a key
# just because a mode-specific file omits it. Do not include "/api" — that's
# appended by src/config.js.
# VITE_API_URL=http://localhost:5000

VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
